{
  "info": {
    "name": "Employee Management System",
    "description": "Complete Postman collection for Spring Boot Employee Management System with JWT Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "admin@company.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user. Returns a JWT token if registration is successful."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login and receive JWT token. Token is auto-saved to collection variable."
          }
        },
        {
          "name": "Register - Duplicate Username (Expect 409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "another@company.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "pass123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Duplicate returns 409', () => pm.response.to.have.status(409));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Employee CRUD",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@company.com\",\n  \"department\": \"Engineering\",\n  \"position\": \"Software Engineer\",\n  \"salary\": 75000.00,\n  \"dateOfJoining\": \"2023-01-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Employee created', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.collectionVariables.set('employee_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Employee 2",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane.smith@company.com\",\n  \"department\": \"HR\",\n  \"position\": \"HR Manager\",\n  \"salary\": 65000.00,\n  \"dateOfJoining\": \"2022-06-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          }
        },
        {
          "name": "Create Employee 3",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Charlie Brown\",\n  \"email\": \"charlie.brown@company.com\",\n  \"department\": \"Engineering\",\n  \"position\": \"Team Lead\",\n  \"salary\": 95000.00,\n  \"dateOfJoining\": \"2020-03-10\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          }
        },
        {
          "name": "Get All Employees (Default Pagination)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees?page=0&size=10&sortBy=id&sortDir=asc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "sortDir",
                  "value": "asc"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Paged response', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.content).to.be.an('array');",
                  "  pm.expect(json.totalElements).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Employees - Sorted by Salary DESC",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees?page=0&size=10&sortBy=salary&sortDir=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "salary"
                },
                {
                  "key": "sortDir",
                  "value": "desc"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Employees - Filter by Department",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees?department=Engineering",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ],
              "query": [
                {
                  "key": "department",
                  "value": "Engineering"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Employees - Search by Name",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees?search=john",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "john"
                }
              ]
            }
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees",
                "1"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Employee data present', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.name).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Employee - Not Found (Expect 404)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees/9999",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees",
                "9999"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Not found returns 404', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"email\": \"john.doe@company.com\",\n  \"department\": \"Engineering\",\n  \"position\": \"Senior Software Engineer\",\n  \"salary\": 90000.00,\n  \"dateOfJoining\": \"2023-01-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees",
                "1"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Salary updated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.salary).to.equal(90000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees",
                "1"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Validation Tests",
      "item": [
        {
          "name": "Create Employee - Missing Fields (Expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"department\": \"\",\n  \"position\": \"\",\n  \"salary\": -100,\n  \"dateOfJoining\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Validation error returns 400', () => pm.response.to.have.status(400));",
                  "pm.test('Validation errors present', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.validationErrors).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Access Without Token (Expect 403)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unauthorized returns 403', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}